# ─────────────────────────────────────────────────────────
# Agency Template — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────

# Site URL (used for OG tags and canonical URLs)
VITE_SITE_URL=https://yourdomain.com

# API base URL (proxied in dev, used directly in prod)
VITE_API_URL=https://api.yourdomain.com

# Contact form endpoint (e.g. Formspree, Resend, custom)
VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Analytics (replace with your Measurement ID)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Optional: Hotjar Site ID
VITE_HOTJAR_ID=
